{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["@vercel/node", "node"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
