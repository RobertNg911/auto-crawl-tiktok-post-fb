{
  "version": 2,
  "builds": [
    {
      "src": "dist/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/system/(.*)", "dest": "/dist/api/system/index.js" },
    { "src": "/api/system", "dest": "/dist/api/system/index.js" },
    { "src": "/api/auth/(.*)", "dest": "/dist/api/auth/index.js" },
    { "src": "/api/auth", "dest": "/dist/api/auth/index.js" },
    { "src": "/api/campaigns/(.*)", "dest": "/dist/api/campaigns/index.js" },
    { "src": "/api/campaigns", "dest": "/dist/api/campaigns/index.js" },
    { "src": "/api/videos/(.*)", "dest": "/dist/api/videos/index.js" },
    { "src": "/api/videos", "dest": "/dist/api/videos/index.js" },
    { "src": "/api/facebook/(.*)", "dest": "/dist/api/facebook/index.js" },
    { "src": "/api/facebook", "dest": "/dist/api/facebook/index.js" },
    { "src": "/api/users/(.*)", "dest": "/dist/api/users/index.js" },
    { "src": "/api/users", "dest": "/dist/api/users/index.js" },
    { "src": "/api/channels/(.*)", "dest": "/dist/api/channels/index.js" },
    { "src": "/api/channels", "dest": "/dist/api/channels/index.js" },
    { "src": "/api/crawler/(.*)", "dest": "/dist/api/crawler/index.js" },
    { "src": "/api/crawler", "dest": "/dist/api/crawler/index.js" },
    { "src": "/api/cron/(.*)", "dest": "/dist/api/cron/index.js" },
    { "src": "/api/cron", "dest": "/dist/api/cron/index.js" },
    { "src": "/api/dashboard/(.*)", "dest": "/dist/api/dashboard/overview.js" },
    { "src": "/api/dashboard", "dest": "/dist/api/dashboard/overview.js" },
    { "src": "/api/webhooks/(.*)", "dest": "/dist/api/webhooks/fb.js" },
    { "src": "/api/webhooks", "dest": "/dist/api/webhooks/fb.js" }
  ]
}
